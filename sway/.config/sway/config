# Sway config -- minimal, Catppuccin Mocha, Agave Nerd Font
# Read `man 5 sway` for a complete reference.

### Variables
set $mod Mod4
# Home row direction keys, like vim
set $left h
set $down j
set $up k
set $right l
set $term kitty
set $term2 foot
set $menu wofi --show drun
set $browser microsoft-edge
set $filemanager nautilus

include /etc/sway/config-vars.d/*

### THEME:COLORS:START (generated by waybar/scripts/cycle-theme.py, do not edit by hand)
set $base     #2e3440
set $text     #eceff4
set $rosewater #eceff4
set $overlay0 #4c566a
set $mauve    #b48ead
set $peach    #d08770
### THEME:COLORS:END

### Appearance
font pango:Agave Nerd Font 11
default_border pixel 2
default_floating_border pixel 2
gaps inner 5
gaps outer 8
smart_gaps off

# class                 border    background text     indicator   child_border
client.focused          $mauve    $base      $text    $rosewater  $mauve
client.focused_inactive $overlay0 $base      $text    $rosewater  $overlay0
client.unfocused        $overlay0 $base      $text    $rosewater  $overlay0
client.urgent           $peach    $base      $text    $peach      $peach
client.placeholder      $overlay0 $base      $text    $overlay0   $overlay0
client.background       $base

### Output
# Single-monitor config -- adapted from Pranav's 3-output laptop+2-external
# layout. Using a wildcard here instead of fixed output names (eDP-1 etc.)
# since this machine has one display and its Wayland output name may not
# match Pranav's hardware. Sway auto-detects resolution/position; add
# explicit `output <name> resolution ... position ...` lines here later if
# you add more monitors.
output * bg ~/dotfiles/wallpapers/diner-lonely-road.jpg fill

### Input
input type:touchpad {
    tap enabled
    natural_scroll enabled
}

### Idle / lock
exec swayidle -w \
         timeout 300 'swaylock -f' \
         timeout 600 'swaymsg "output * power off"' resume 'swaymsg "output * power on"' \
         before-sleep 'swaylock -f'

### Key bindings
#
# Basics:
#
    bindsym $mod+Return exec $term
    bindsym $mod+Shift+Return exec $term2
    bindsym $mod+q kill
    bindsym $mod+Shift+q kill
    bindsym $mod+d exec $menu
    bindsym $mod+Escape exec swaylock -f
    bindsym $mod+l exec swaylock -f
    bindsym $mod+Ctrl+l exec swaylock -f

    # Apps (ported from adithya-r-prabhu/bspwm's sxhkd bindings). bspwm had
    # `super+q` = close window and `super+w` = browser with no Shift needed
    # -- matched here directly ($mod+q added above as a plain-kill alias,
    # and browser moved to plain $mod+w). Sway's own `layout tabbed`, which
    # normally lives on $mod+w, is moved to $mod+Shift+w instead so nothing
    # is lost, just relocated (see the "Layout stuff" section below).
    bindsym $mod+w exec $browser
    bindsym $mod+n exec $filemanager

    # Power menu / cheat-sheet / emoji picker. Power menu reuses waybar's
    # existing wofi-based script (also on the waybar power icon's on-click)
    # rather than duplicating one; cheat-sheet/emoji picker are ported from
    # bspwm's rofi scripts, rewritten for wofi -- see sway/scripts/*.sh.
    # Replaces the old swaynag exit-confirm binding; the Logout option here
    # covers that same case.
    bindsym $mod+Shift+e exec ~/.config/waybar/scripts/powermenu.sh
    bindsym $mod+F1 exec ~/.config/sway/scripts/keybind-cheatsheet.sh
    bindsym $mod+Ctrl+e exec ~/.config/sway/scripts/emoji-picker.sh

    # Screenshot region+save+clipboard (grim+slurp -- see script comment for
    # why this replaces flameshot, which doesn't render on this setup at all)
    bindsym Alt+s exec ~/.config/sway/scripts/screenshot-region.sh

    # "Connecting" shortcuts: Wi-Fi/ethernet menu and Bluetooth manager.
    # The network menu already exists as a waybar click action
    # (~/.config/waybar/scripts/networkmenu.sh) -- this just adds a
    # keyboard shortcut for it, no new script needed.
    bindsym $mod+Shift+n exec ~/.config/waybar/scripts/networkmenu.sh
    bindsym $mod+Shift+b exec blueman-manager

    # Quick access to waybar's existing theme-cycle / wallpaper-picker /
    # monitor-layout tools without needing to click the bar.
    bindsym $mod+Shift+t exec ~/.config/waybar/scripts/cycle-theme.py
    bindsym $mod+Shift+p exec ~/.config/waybar/scripts/wallpaper-picker.sh
    bindsym $mod+Shift+m exec wdisplays

    # Clipboard history (CopyQ -- daemon started below in "Start
    # applications" via --start-server, hidden until toggled)
    bindsym $mod+Ctrl+v exec copyq toggle

    # Drag floating windows by holding down $mod and left mouse button.
    # Resize them with right mouse button + $mod.
    floating_modifier $mod normal

    bindsym $mod+Shift+c reload
#
# Moving around:
#
    bindsym $mod+$left focus left
    bindsym $mod+$down focus down
    bindsym $mod+$up focus up
    bindsym $mod+Left focus left
    bindsym $mod+Down focus down
    bindsym $mod+Up focus up
    bindsym $mod+Right focus right

    bindsym $mod+Shift+$left move left
    bindsym $mod+Shift+$down move down
    bindsym $mod+Shift+$up move up
    bindsym $mod+Shift+$right move right
    bindsym $mod+Shift+Left move left
    bindsym $mod+Shift+Down move down
    bindsym $mod+Shift+Up move up
    bindsym $mod+Shift+Right move right
#
# Workspaces:
#
    bindsym $mod+1 workspace number 1
    bindsym $mod+2 workspace number 2
    bindsym $mod+3 workspace number 3
    bindsym $mod+4 workspace number 4
    bindsym $mod+5 workspace number 5
    bindsym $mod+6 workspace number 6
    bindsym $mod+7 workspace number 7
    bindsym $mod+8 workspace number 8
    bindsym $mod+9 workspace number 9
    bindsym $mod+0 workspace number 10
    bindsym $mod+Shift+1 move container to workspace number 1
    bindsym $mod+Shift+2 move container to workspace number 2
    bindsym $mod+Shift+3 move container to workspace number 3
    bindsym $mod+Shift+4 move container to workspace number 4
    bindsym $mod+Shift+5 move container to workspace number 5
    bindsym $mod+Shift+6 move container to workspace number 6
    bindsym $mod+Shift+7 move container to workspace number 7
    bindsym $mod+Shift+8 move container to workspace number 8
    bindsym $mod+Shift+9 move container to workspace number 9
    bindsym $mod+Shift+0 move container to workspace number 10
#
# Layout stuff:
#
    bindsym $mod+b splith
    bindsym $mod+v splitv
    bindsym $mod+s layout stacking
    bindsym $mod+Shift+w layout tabbed
    bindsym $mod+e layout toggle split
    bindsym $mod+f fullscreen
    bindsym $mod+Shift+space floating toggle
    bindsym $mod+space focus mode_toggle
    bindsym $mod+a focus parent
#
# Scratchpad:
#
    bindsym $mod+Shift+minus move scratchpad
    bindsym $mod+minus scratchpad show
#
# Resizing containers:
#
mode "resize" {
    bindsym $left resize shrink width 10px
    bindsym $down resize grow height 10px
    bindsym $up resize shrink height 10px
    bindsym $right resize grow width 10px

    bindsym Left resize shrink width 10px
    bindsym Down resize grow height 10px
    bindsym Up resize shrink height 10px
    bindsym Right resize grow width 10px

    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"
#
# Utilities:
#
    bindsym --locked XF86AudioMute exec pactl set-sink-mute @DEFAULT_SINK@ toggle && ~/.config/sway/scripts/osd.sh volume
    bindsym --locked XF86AudioLowerVolume exec pactl set-sink-volume @DEFAULT_SINK@ -5% && ~/.config/sway/scripts/osd.sh volume
    bindsym --locked XF86AudioRaiseVolume exec pactl set-sink-volume @DEFAULT_SINK@ +5% && ~/.config/sway/scripts/osd.sh volume
    bindsym --locked XF86AudioMicMute exec pactl set-source-mute @DEFAULT_SOURCE@ toggle && ~/.config/sway/scripts/osd.sh mic
    bindsym --locked XF86MonBrightnessDown exec brightnessctl set 5%- && ~/.config/sway/scripts/osd.sh brightness
    bindsym --locked XF86MonBrightnessUp exec brightnessctl set 5%+ && ~/.config/sway/scripts/osd.sh brightness

    # Screenshots (grim + slurp + wl-clipboard)
    bindsym Print exec mkdir -p ~/Pictures/Screenshots && grim ~/Pictures/Screenshots/$(date +'%Y-%m-%d_%H-%M-%S').png
    bindsym $mod+Shift+s exec grim -g "$(slurp)" - | wl-copy

include /etc/sway/config.d/*

### Window rules
# Ported from adithya-r-prabhu/bspwm's bspwmrc `bspc rule` lines
# (browser -> a dedicated workspace, calculator/screenshot tool floating).
assign [app_id="microsoft-edge"] workspace number 2
for_window [app_id="gnome-calculator"] floating enable
# CopyQ: always floating (never tiles like a regular window), fixed size,
# centered, and given a normal titlebar+close-button -- unlike the rest of
# this theme's borderless "pixel" style windows, since this is meant to be
# a quick popup you open/close often and clicking an X is the most
# discoverable way to dismiss it (Escape and $mod+Ctrl+v also both close/
# hide it -- see keybindings above).
for_window [app_id="com.github.hluk.copyq"] floating enable, border normal, resize set 500 500, move position center

# Start applications
exec waybar
exec mako
exec copyq --start-server
exec nm-applet --indicator
exec blueman-applet
